{
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.errorSquiggles": "enabled",
    "files.associations": {
        "*.syscfg": "javascript",
        "FreeRTOSConfig.h": "c"
    },
    "search.exclude": {
